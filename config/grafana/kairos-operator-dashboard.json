{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Reconciliation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(controller_runtime_reconcile_total{namespace=\"kairos-system\"}[5m])) by (controller)",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Reconciliation Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(controller_runtime_reconcile_errors_total{namespace=\"kairos-system\"}[5m])) by (controller)",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Reconciliation Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(controller_runtime_reconcile_time_seconds_bucket{namespace=\"kairos-system\"}[5m])) by (le, controller))",
          "legendFormat": "p99 {{controller}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(controller_runtime_reconcile_time_seconds_bucket{namespace=\"kairos-system\"}[5m])) by (le, controller))",
          "legendFormat": "p50 {{controller}}",
          "refId": "B"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Work Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "workqueue_depth{namespace=\"kairos-system\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Kubernetes API Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(rest_client_requests_total{namespace=\"kairos-system\"}[5m])) by (code)",
          "legendFormat": "HTTP {{code}}",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Go Runtime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "go_goroutines{namespace=\"kairos-system\", job=~\".*kairos.*\"}",
          "legendFormat": "goroutines",
          "refId": "A"
        },
        {
          "expr": "process_resident_memory_bytes{namespace=\"kairos-system\", job=~\".*kairos.*\"} / 1024 / 1024",
          "legendFormat": "RSS (MiB)",
          "refId": "B"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Kairos Corrections per Hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(increase(controller_runtime_reconcile_total{namespace=\"kairos-system\", controller=\"kairosagent\", result=\"success\"}[1h]))",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Active Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "targets": [
        {
          "expr": "count(kube_customresource_kairos_agent_info) or vector(0)",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Watched Resources",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(kairos_agent_watched_resources) or vector(0)",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    },
    {
      "title": "Pending Approvals",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "sum(kairos_agent_pending_approvals) or vector(0)",
          "refId": "A"
        }
      ],
      "datasource": "${DS_PROMETHEUS}"
    }
  ],
  "schemaVersion": 39,
  "tags": ["kairos", "operator", "kubernetes"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Kairos Operator",
  "uid": "kairos-operator",
  "version": 1
}
